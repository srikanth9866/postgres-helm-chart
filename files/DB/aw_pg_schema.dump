    data public.citext NOT NULL,
    data_unit public.citext,
    extra_data public.citext,
    sms public.citext,
    extra_sms public.citext,
    service_type public.citext NOT NULL,
    provision_code1 public.citext,
    created_on public.citext,
    updated_on public.citext,
    created_by public.citext,
    updated_by public.citext,
    extra_voice_unit_name public.citext,
    extra_data_unit_name public.citext,
    period_type public.citext NOT NULL,
    additional_details public.citext,
    destination_country public.citext,
    partner_network public.citext,
    service_class public.citext,
    product_offer_id public.citext,
    refill_id public.citext,
    segment_details public.citext,
    valid_from public.citext,
    valid_upto public.citext,
    isbundleautorenewal public.citext NOT NULL,
    display_priority public.citext NOT NULL,
    amount_currency public.citext,
    _created integer,
    _updated integer,
    _created_by uuid,
