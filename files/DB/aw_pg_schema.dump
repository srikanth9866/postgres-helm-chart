    is_login_approved integer,
    is_logout_approved integer,
    login_approver_time timestamp without time zone,
    login_attendance_status character varying(255),
    login_comments character varying(255),
    login_image character varying(900),
    login_latitude double precision,
    login_longitude double precision,
    login_time timestamp without time zone,
    user_login_remarks character varying(255),
    logout_approver_time timestamp without time zone,
    logout_attendance_status character varying(255),
    logout_comments character varying(255),
    logout_image character varying(900),
    logout_latitude double precision,
    logout_longitude double precision,
    logout_time timestamp without time zone,
    user_logout_remarks character varying(255),
    user_msisdn character varying(255),
    user_id uuid,
    tenant_id uuid,
    work_duration_minutes bigint,
    org_process_path character varying(255),
    role_label character varying(255),
    user_rolepath character varying(255),
    user_operating_boundary_map jsonb,
    userrole_id uuid,
    userrole_metadata jsonb,
    username character varying(255),
    name character varying(255),
    olm_id character varying(255),
    platforms text[],
    is_manager_overwrite integer,
    source_channel character varying(255),
    lob character varying(255),
    store_id character varying(255),
    manager_user_id uuid,
    meta_info jsonb
);


