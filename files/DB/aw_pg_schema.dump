--
-- Name: EXTENSION "uuid-ossp"; Type: COMMENT; Schema: -; Owner: 
--

COMMENT ON EXTENSION "uuid-ossp" IS 'generate universally unique identifiers (UUIDs)';


--
-- Name: repeat_rs; Type: TYPE; Schema: public; Owner: postgres
--

CREATE TYPE public.repeat_rs AS (
	v_col1 text,
	v_col2 text,
	v_col3 text,
	v_col4 text,
	v_col5 text
);


ALTER TYPE public.repeat_rs OWNER TO postgres;

--
-- Name: distance(double precision, double precision, double precision, double precision); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.distance(lat1 double precision, lng1 double precision, lat2 double precision, lng2 double precision) RETURNS double precision
    LANGUAGE plpgsql
    AS $$
DECLARE
    x float = 69.1 * (lat2 - lat1);
    y float = 69.1 * (lng2 - lng1) * cos(lat1 / 57.3);
BEGIN
    RETURN sqrt(x * x + y * y);
END

$$;


ALTER FUNCTION public.distance(lat1 double precision, lng1 double precision, lat2 double precision, lng2 double precision) OWNER TO postgres;

--
-- Name: get_hierarchy_json(uuid); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.get_hierarchy_json(val uuid) RETURNS jsonb
    LANGUAGE plpgsql
    AS $$
Declare vFSE_HIER Repeat_rs;
    declare l_counter integer;
    declare v_c1 varchar(10000);
    declare v_c2 varchar(10000);
    declare v_c3 varchar(10000);
    declare v_c4 varchar(10000);
    declare v_c5 varchar(10000);
    declare ret_str varchar(100000);
        ret_str_final jsonb;
BEGIN
    ret_str:='{';
    FOR vFSE_HIER IN WITH recursive userrole_hierarchy AS
                                        (
                                            SELECT ur.user_id AS id,
                                                   ur._id     AS userrole_id,
                                                   ur.reporting_to_id,
                                                   ur.organisation_id,
                                                   ur.role_id,
                                                   0 as level
                                            FROM userrole ur
                                                     LEFT JOIN role r ON ur.role_id = r._id
                                            WHERE ur._id = val
                                            UNION
                                            SELECT rm.user_id AS id,
                                                   rm._id     AS userrole_id,
                                                   rm.reporting_to_id,
                                                   rm.organisation_id,
                                                   rm.role_id,
                                                   level + 1
                                            FROM userrole rm,
                                                 userrole_hierarchy ur
                                            WHERE rm._id = ur.reporting_to_id and level<50)
                     SELECT
                         r.role_label as role_label,
                         ur.userrole_id as userrole_id,
                         u.msisdn as msisdn,
                         ur.reporting_to_id as reporting_to_id,
                         u.name as name
                     FROM userrole_hierarchy ur
                              LEFT JOIN public.user u
                                        ON u._id = ur.id
                              LEFT JOIN role r
                                        ON ur.role_id = r._id
                              LEFT JOIN organisation o
                                        ON ur.organisation_id = o._id
                     order by level
        LOOP
            case when length(ret_str)=1 then
                ret_str:=ret_str;
                else
                    ret_str:=concat(ret_str,',');
                end case ;
            ret_str:=concat(ret_str,'"', REPLACE(lower(vFSE_HIER.v_col1), ' ', '_') ,'":{"userrole_id":"',vFSE_HIER.v_col2,'","msisdn":"',vFSE_HIER.v_col3,'","reporting_to_id":"',vFSE_HIER.v_col4,'","name":"', regexp_replace(vFSE_HIER.v_col5, '       ', '', 'g') ,'"}');
        END LOOP;
    ret_str_final:=concat(ret_str,'}')::jsonb;
    return ret_str_final;
END;
$$;


ALTER FUNCTION public.get_hierarchy_json(val uuid) OWNER TO postgres;

--
-- Name: user_role_daily_process(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.user_role_daily_process() RETURNS boolean
    LANGUAGE plpgsql
    AS $$
DECLARE
    CURRENT_USER_ROLE_ID uuid;
BEGIN

        UPDATE user_hierarchy set _is_active = false , updated_at = (NOW()::timestamp) where userrole_id not in (SELECT _id from userrole );

        INSERT INTO user_hierarchy
    (userrole_id, organistion_id, organisation_path_slug, reporting_to_id, userrole_created_at, userrole_updated_at, user_id, role_id, name, msisdn, email, olm_id, tenant_id, platforms,operating_boundaries,
     role_level, reportees_level, role_path, role_path_slug, role_label, role_type, userrole_metadata, _is_active, userrole_operating_boundaries, hierarchy, created_at, updated_at,organisation_label, employee_id, organisation_spoc_msisdn, organisation_spoc_name,
     organisation_entity_id, organisation_entity_name, organisation_address)
        (SELECT ur._id as userrole_id, ur.organisation_id as organistion_id,org.organisation_path_slug as organisation_path_slug ,ur.reporting_to_id as reporting_to_id,
                ur._created as userrole_created_at,ur._updated as userrole_updated_at,
                u._id as user_id, ur.role_id as role_id, u.name as name ,u.msisdn as msisdn,u.email as email,u.olm_id as olm_id,u._tenant_id as tenant_id,u.platforms as platforms,
                rl.operating_boundaries as operating_boundaries ,rl.role_level as role_level,rl.reportees_level as reportees_level ,
                rl.role_path as role_path,
                rl.role_path_slug as role_path_slug,rl.role_label as role_label,rl.role_type as role_type ,
                ur.metadata as  userrole_metadata,ur._is_active as _is_active,
                TT1.jsonstr AS userrole_operating_boundaries,
                 get_hierarchy_json(ur._id) as hierarchy,
                (NOW())::timestamp as created_at ,(NOW())::timestamp as updated_at,
                        org.organisation_label as organisation_label, u.employee_id as employee_id,
                        orge.spoc_msisdn as organisation_spoc_msisdn,
                        orge.spoc_name as organisation_spoc_name,
                        orge.entity_id as organisation_entity_id,
                        orge.entity_name as organisation_entity_name,
                        orge.address as organisation_address
         from ((((userrole ur INNER JOIN "user" u ON  ur.user_id=u._id )  LEFT JOIN role rl ON ur.role_id = rl._id) LEFT JOIN organisation org on org._id = ur.organisation_id ) LEFT JOIN organisation_entity orge on org.organisation_entity_id = orge._id)
                  LEFT JOIN
                 (select _id,concat('{',string_agg(jsonval,','),'}')::jsonb jsonstr from ( SELECT ur._id,concat('"',lower(ob.operating_boundary_label),'":',json_agg( ob.operating_boundary_path),',"',concat(lower(ob.operating_boundary_label),'_value'),'":',json_agg( ob.operating_boundary_value) ) jsonval
        FROM ((operating_boundary  ob INNER JOIN  userrole_operating_boundary urob ON ob._is_active = true AND urob.operating_boundary_id = ob._id
            INNER JOIN userrole ur ON ur._id = urob.userrole_id)) WHERE
ur._is_active=true  and ob.operating_boundary_label<>'pillar or primary splitter'
         GROUP BY ur._id,lower(ob.operating_boundary_label) ) t1
                 GROUP BY _id) TT1 on (TT1._id=ur._id)
        )
    ON CONFLICT (userrole_id) DO
        UPDATE
        SET
            organistion_id = excluded.organistion_id,
            reporting_to_id =  excluded.reporting_to_id ,
            user_id = excluded.user_id,
            name = excluded.name,
            msisdn = excluded.msisdn,
            email = excluded.email,
            olm_id = excluded.olm_id,
            tenant_id = excluded.tenant_id,
            operating_boundaries = excluded.operating_boundaries,
            role_level = excluded.role_level,
            reportees_level = excluded.reportees_level ,
            role_path = excluded.role_path ,
            role_path_slug = excluded.role_path_slug ,
            role_label = excluded.role_label,
            role_type = excluded.role_type,
            userrole_operating_boundaries = excluded.userrole_operating_boundaries ,
            hierarchy = excluded.hierarchy ,
            updated_at = excluded.updated_at,
            role_id = excluded.role_id,
            userrole_metadata = excluded.userrole_metadata,
            organisation_path_slug = excluded.organisation_path_slug,
            platforms = excluded.platforms,
            userrole_created_at = excluded.userrole_created_at,
            userrole_updated_at = excluded.userrole_updated_at,
            _is_active = excluded._is_active,
            organisation_label=excluded.organisation_label,
            employee_id=excluded.employee_id,
            organisation_spoc_msisdn = excluded.organisation_spoc_msisdn,
            organisation_spoc_name = excluded.organisation_spoc_name,
            organisation_entity_id = excluded.organisation_entity_id,
            organisation_entity_name = excluded.organisation_entity_name,
            organisation_address = excluded.organisation_address;

    RETURN true;
END;
$$;


ALTER FUNCTION public.user_role_daily_process() OWNER TO postgres;

