    allocated_by_name character varying(255),
    appointment_date timestamp without time zone,
    appointment_finish character varying(255),
    appointment_start character varying(255),
    close_task_details jsonb,
    common_details jsonb,
    contact_phone_number character varying(255),
    corelation_id character varying(255),
    created_date timestamp without time zone,
    customer character varying(255),
    customer_id character varying(255),
    district character varying(255),
    fse_msisdn character varying(255),
    fse_name character varying(255),
    modified_date timestamp without time zone,
    new_order_id character varying(255),
    open_date timestamp without time zone,
    order_id character varying(255),
    order_type character varying(255),
    pending_with character varying(255),
    pending_with_details character varying(255),
    pincode character varying(255),
    region character varying(255),
    remarks character varying(2000),
    sla_check_for bigint,
    sla_date timestamp without time zone,
    sla_minutes_left character varying(255),
    sla_status character varying(255),
    sla_time character varying(255),
    sla_ttl character varying(255),
    status character varying(255),
    task_required_skill character varying(255),
    task_type character varying(255),
    agency_id character varying(255),
    fse_id character varying(255),
    circle character varying(255),
    city character varying(255),
    plan_type character varying(255),
    product_type character varying(255),
    sr_number character varying(255),
    state character varying(255),
    organisation_path_slug public.ltree,
    tenant_id character varying(255),
    tenant_name character varying(255),
    source_channel character varying(255),
    customer_latitude character varying(255),
    customer_longitude character varying(255),
    organisation_process_path public.ltree,
    lead_id character varying(255),
    cart_id character varying(255),
    rsu character varying(255),
    zone character varying(255),
    operating_boundary_path public.ltree,
    pending_with_id character varying(255),
    dynamic_data jsonb,
    documents_meta_data_with_url jsonb,
    external_system_data jsonb,
    pending_with_role character varying(255),
    circle_id character varying(255),
    quote_item_id character varying(255),
    call_id character varying(50),
    item_order_type character varying(255),
    pagination integer,
    sub_product_type character varying(255),
    parent_order_id character varying(255),
    parent_correlation_id character varying(255),
    follow_up_date character varying(255),
    follow_up_time character varying(255),
    payment_status character varying(255),
    is_migrated boolean DEFAULT false,
    service_version character varying(100),
    migrated_txn character varying(255) DEFAULT false,
    reference_id character varying(100),
    viewtask_priority bigint,
    assignees text[],
    parent_created_date timestamp without time zone,
    sub_status character varying(255),
    company_name character varying(100),
    hierarchy jsonb,
    one_airtel_suborder boolean DEFAULT false,
    completed_date timestamp without time zone,
    action character varying(255),
    action_performed_by character varying(255)
)
PARTITION BY RANGE (created_date);


