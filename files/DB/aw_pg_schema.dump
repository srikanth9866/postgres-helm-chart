--
-- Name: ffcrc_sync(); Type: PROCEDURE; Schema: public; Owner: postgres
--

CREATE PROCEDURE public.ffcrc_sync()
    LANGUAGE plpgsql
    AS $$
DECLARE vcount integer default 0;
DECLARE rowcount integer default 0;
DECLARE rowcount1 integer default 0;
DECLARE query_r  text default '';
BEGIN

select count(*) into vcount from temp_ffcrc;
if vcount>100 then
insert into ffcrc02jun22(problem_type,problem_subtype,product_type,ffc,rc,_created,_created_by,_is_active)
select sr_type,sr_sub_type,product,ffc,rc,round(extract(epoch from current_timestamp))::integer _created ,
'0cdd5a66-f6a1-4bb4-aacf-030d44b7e9e8'::uuid _created_by,true::boolean _is_active 
from (select  distinct sr_type,sr_sub_type,product,ffc,rc from temp_ffcrc where 
(sr_type::text,sr_sub_type::text,product::text,ffc::text,rc::text) not in (select problem_type::text,problem_subtype::text,product_type::text,ffc::text,rc::text
 from ffcrc02jun22) ) t1;
GET DIAGNOSTICS rowcount=ROW_COUNT;
insert into hist_ffcrc02jun22(srno,problem_type,problem_subtype,product_type,ffc,rc,_created,
_updated,_created_by,_updated_by,_is_active)
select srno,problem_type,problem_subtype,product_type,ffc,rc,_created,
round(extract(epoch from current_timestamp))::integer _updated,_created_by,_updated_by,_is_active 
from ffcrc02jun22 where (problem_type::text,problem_subtype::text,product_type::text,ffc::text,rc::text)
not in (select sr_type::text,sr_sub_type::text,product::text,ffc::text,rc::text from temp_ffcrc);

delete from ffcrc02jun22 where (problem_type::text,problem_subtype::text,product_type::text,ffc::text,rc::text)
not in (select sr_type::text,sr_sub_type::text,product::text,ffc::text,rc::text from temp_ffcrc);
GET DIAGNOSTICS rowcount1=ROW_COUNT;
query_r= 'inserted:'||rowcount||'; deleted:'||rowcount1;
raise notice '%', query_r;
else 
query_r= 'rows less than 100 in temp_ffcrc';
raise notice '%', query_r;
end if;

END
$$;


ALTER PROCEDURE public.ffcrc_sync() OWNER TO postgres;

